# =============================
# NoteTaker Hybrid RAG (.env)
# =============================

# --- API ---
API_HOST=0.0.0.0
API_PORT=8001

# --- JWT / SSO ---
# IMPORTANTE: debe coincidir con auth_sso/main.py
# (COSMOS_SECRET_KEY + COSMOS_JWT_ALG)
COSMOS_SECRET_KEY=replace-with-strong-shared-secret
COSMOS_JWT_ALG=HS256

# Compatibilidad legacy (opcionales):
# SECRET_KEY=
# JWT_SECRET_KEY=
# AUTH_SECRET_KEY=
# ALGORITHM=
# JWT_ALGORITHM=

# --- Qdrant ---
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
QDRANT_COLLECTION=notetaker_meetings

# --- Embeddings local cache ---
LOCAL_EMBED_DIR=./models/sentence-t5-base
EMBED_MODEL_NAME=sentence-transformers/sentence-t5-base

# --- Chunking ---
CHUNK_SIZE=4000
CHUNK_OVERLAP=800

# --- Neo4j ---
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-with-neo4j-password
